rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktionen
    function isAuthenticated() {
      return request.auth != null;
    }

    function isFamilyMember(familyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isFamilyOwner(familyId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'OWNER';
    }

    function isFamilyAdminOrOwner(familyId) {
      let role = get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role;
      return isAuthenticated() && (role == 'OWNER' || role == 'ADMIN');
    }

    // Familien-Dokument
    match /families/{familyId} {
      // list: erlaubt Collection-Query (z.B. whereEqualTo("inviteCode", ...)) für
      //        jeden eingeloggten Nutzer — nötig zum Beitreten per Einladungscode.
      //        Sicher, da Codes 8-stellig zufällig sind (~1 Billion Kombinationen).
      // get:  Einzeldokument nur für Mitglieder lesbar.
      allow list: if isAuthenticated();
      allow get: if isFamilyMember(familyId);
      allow create: if isAuthenticated();
      allow update: if isFamilyAdminOrOwner(familyId);
      allow delete: if isFamilyOwner(familyId);

      // Familienmitglieder
      match /members/{userId} {
        allow read: if isFamilyMember(familyId);
        // Neues Mitglied darf sich selbst eintragen (join via invite code)
        allow create: if isAuthenticated() && request.auth.uid == userId;
        // Owner/Admin darf Rollen ändern
        allow update: if isFamilyAdminOrOwner(familyId);
        // Nur Owner darf Mitglieder entfernen (außer eigenes Leave)
        allow delete: if isFamilyOwner(familyId) || request.auth.uid == userId;
      }

      // Haustiere
      match /pets/{petId} {
        allow read, write: if isFamilyMember(familyId);

        // Fotos
        match /photos/{photoId} {
          allow read, write: if isFamilyMember(familyId);
        }
      }
    }
  }
}
