<?xml version="1.0" encoding="utf-8"?>
<!--
    Platzhalter-Foreground: Stilisierter Pfotenabdruck in Brand-Terracotta (#C75B39).
    Safe Zone: 18dp–90dp (72dp-Kreis). Alle Formen liegen innerhalb dieser Zone.
    5 Kreise (4 Zehenballen + 1 Hauptballen) als Arc-Pfade approximiert.
    Ersetze pathData gegen echtes Tiermotiv vor dem finalen Release.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!--
        Pfotenabdruck: 4 Zehenballen oben + 1 großer Hauptballen unten.
        Jeder Kreis: M cx-r,cy  a r,r 0 1,0 2r,0  a r,r 0 1,0 -2r,0 Z
    -->
    <path
        android:fillColor="#C75B39"
        android:pathData="
            M 28,47 a 8,8 0 1,0 16,0 a 8,8 0 1,0 -16,0 Z
            M 42,41 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z
            M 56,41 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0 Z
            M 68,47 a 8,8 0 1,0 16,0 a 8,8 0 1,0 -16,0 Z
            M 38,66 a 16,14 0 1,0 32,0 a 16,14 0 1,0 -32,0 Z" />
</vector>
